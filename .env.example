# ===== GEMINI AI CHATBOT CONFIGURATION =====
# Copy this file to .env and fill in your actual API keys
# DO NOT commit the .env file to version control

# Gemini API Key (get yours from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# ===== DATABASE CONFIGURATION (Optional) =====
# Uncomment and modify if you want to override defaults
# SPRING_DATASOURCE_URL=jdbc:h2:file:./data/vintage_pharmacy_db
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=

# ===== SECURITY =====
# Session timeout (default: 30m)
# SERVER_SERVLET_SESSION_TIMEOUT=30m

